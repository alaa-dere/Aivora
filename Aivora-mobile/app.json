{
  "expo": {
    "name": "Aivora",
    "slug": "Aivora-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo2.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d3b66"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Aivora to use your camera to take a profile photo.",
        "NSPhotoLibraryUsageDescription": "Allow Aivora to access your photos to choose a profile photo.",
        "NSPhotoLibraryAddUsageDescription": "Allow Aivora to save selected profile photos when needed."
      },
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0d3b66"
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0d3b66"
      },
      "adaptiveIcon": {
        "backgroundColor": "#0d3b66",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Aivora to access your photos to choose a profile photo.",
          "cameraPermission": "Allow Aivora to use your camera to take a profile photo."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
